<nav class="c-docs-toc{{ variant }}">
	<div class="c-docs-toc__row">
		<p>
			<strong
				><a class="c-docs-toc__link" href="/" {%- if page.url == "/" %}aria-current="page"{%- endif %}>Welcome</a></strong
			>
		</p>
	</div>
	{%- if not variant %}
	<hr />
	{%- endif %}
	{%- set topics = collections.docs | groupby("data.topicTitle") %}
	{%- for topic, items in topics %}
		{% set topicSlug = items[0].data.topicSlug %}
		{%- set topicHref = "/docs/" ~ topicSlug ~ "/" %}
		{%- if loop.index0 >= 1 %}

			<div class="c-docs-toc__item {{ "active" if topicSlug === _ctx().topicSlug }}">
				<div class="c-docs-toc__row">
					<p>
						<strong
							><a
								class="c-docs-toc__link"
								href="{{ topicHref }}"
								{%- if page.url === topicHref %}aria-current="page"{%- endif %}
								>{{ topic }}</a
							></strong
						>
					</p>
					<button class="c-docs-toc__menu__caret" aria-expanded="false" aria-label="Toggle Concepts">
						<svg width="16" height="16" fill="currentColor" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M297.4 438.6C309.9 451.1 330.2 451.1 342.7 438.6L502.7 278.6C515.2 266.1 515.2 245.8 502.7 233.3C490.2 220.8 469.9 220.8 457.4 233.3L320 370.7L182.6 233.4C170.1 220.9 149.8 220.9 137.3 233.4C124.8 245.9 124.8 266.2 137.3 278.7L297.3 438.7z"/></svg></button>
				</div>
			</div>

			<div class="c-docs-toc__children" hidden="true">
				<ul class="c-docs-toc__block">
					{%- for item in items %}
						{%- if item.page.fileSlug !== "00.index" %}
							<li>
								<a
									class="c-docs-toc__link"
									href="{{ item.page.url }}"
									{%- if page.url === item.page.url %}aria-current="page"{%- endif %}
									>{{ item.data.title }}</a
								>
							</li>
						{%- endif %}
					{%- endfor %}
				</ul>
			</div>
			{%- if not variant %}
				<hr />
			{%- endif %}
		{%- endif %}
	{%- endfor %}
</nav>
