{% extends "layouts/base.njk" %}

{%- block content %}
{%- include "components/c-docs-toc--details.njk" %}
<div class="l-document">

	<!-- sidebar -->
	<div class="l-document__sidebar">{% include "components/c-docs-toc--sidebar.njk" %}</div>

	<!-- content -->
	<div class="l-document__content u-flow">
		<nav class="c-breadcrumbs" aria-label="Breadcrumb">
			<ol>
				{%- for c in _pageContext.entry.breadcrumbs %}
					<li>
						{%- if c.current %}<span aria-current="page">{{ c.label }}</span>
						{%- else %}<a href="{{ c.url }}">{{ c.label }}</a>{%- endif %}
					</li>
				{%- endfor %}
			</ol>
		</nav>
		<article class="u-flow">
			<h1>{{ title }}</h1>
			{{ content | safe }}
		</article>
		<div style="margin-block-start: var(--space-2xl); border-top: 1px solid var(--color-border);">
			{%- include "partials/docs-nav.njk" %}
		</div>
		<div style="margin-block-start: var(--space-2xl)"></div>
	</div>

	<!-- aside -->
	<div class="l-document__aside u-flow">{% include "partials/document-aside.njk" %}</div>

</div>
{%- endblock %}
