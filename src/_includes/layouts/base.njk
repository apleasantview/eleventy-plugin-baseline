<!DOCTYPE html>
<html lang="{{ lang | default(settings.defaultLanguage) }}">
	<baseline-head></baseline-head>
	<body>
		<a href="#main" class="skip-link"> Skip to main content </a>
		<div class="">
			<div class="u-wrapper c-top-bar">
				<div>{%- include "partials/theme-switcher.njk" %}&emsp;{% include "partials/language-switcher.njk" %}</div>
			</div>
		</div>
		{%- include "components/header.njk" %}
		<main id="main" tabindex="-1">
			<div class="u-wrapper">
				{%- block content %}
					<p>No content found.</p>
				{%- endblock %}
			</div>
		</main>
		<footer>
			<div class="u-wrapper">
				<div>{%- include "partials/theme-switcher.njk" %}&emsp;{% include "partials/language-switcher.njk" %}</div>
				<div>
					<small>revision: {{ helpers.buildCommit() | safe }}</small>&emsp;<small
						>npm:
						<a href="https://www.npmjs.com/package/@apleasantview/eleventy-plugin-baseline" target="_blank"
							>0.1.0-next.39</a
						></small
					>
				</div>
			</div>
		</footer>
	</body>
</html>
