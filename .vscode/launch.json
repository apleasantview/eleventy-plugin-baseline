{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug 11ty (dryrun)",
			"request": "launch",
			"type": "node-terminal",
			"command": "npm run dryrun",
			"cwd": "${workspaceFolder}",
			"env": {
				"ELEVENTY_ENV": "development",
				"URL": "http://localhost:8080/"
			}
		},
		{
			"name": "Debug 11ty (serve)",
			"request": "launch",
			"type": "node-terminal",
			"command": "npm run dev",
			"cwd": "${workspaceFolder}",
			"env": {
				"ELEVENTY_ENV": "development",
				"URL": "http://localhost:8080/"
			}
		},
		{
			"name": "Logged debug 11ty",
			"request": "launch",
			"type": "node-terminal",
			"command": "npm run debug:log",
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "Run tests",
			"request": "launch",
			"type": "node-terminal",
			"command": "npm test",
			"cwd": "${workspaceFolder}"
		}
	]
}
